{
  "name": "@i2c/intelligence",
  "version": "0.0.3",
  "description": "Unified Next.js intelligence toolkit: compiler, core analyzer, runtime hooks, dashboard, and shared types.",
  "type": "module",
  "main": "./dist/tools/intelligence-core/src/index.js",
  "module": "./dist/tools/intelligence-core/src/index.js",
  "types": "./dist/tools/intelligence-types/src/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/tools/intelligence-core/src/index.d.ts",
      "import": "./dist/tools/intelligence-core/src/index.js"
    },
    "./core": {
      "types": "./dist/tools/intelligence-core/src/index.d.ts",
      "import": "./dist/tools/intelligence-core/src/index.js"
    },
    "./core/analyzer": {
      "types": "./dist/tools/intelligence-core/src/analyzer/index.d.ts",
      "import": "./dist/tools/intelligence-core/src/analyzer/index.js"
    },
    "./compiler": {
      "types": "./dist/tools/intelligence-compiler/src/index.d.ts",
      "import": "./dist/tools/intelligence-compiler/src/index.js"
    },
    "./compiler/next-plugin": {
      "types": "./dist/tools/intelligence-compiler/src/next-plugin.d.ts",
      "import": "./dist/tools/intelligence-compiler/src/next-plugin.js"
    },
    "./runtime": {
      "types": "./dist/tools/intelligence-runtime/src/index.d.ts",
      "import": "./dist/tools/intelligence-runtime/src/index.js"
    },
    "./dashboard": {
      "types": "./dist/tools/intelligence-dashboard/src/index.d.ts",
      "import": "./dist/tools/intelligence-dashboard/src/index.js"
    },
    "./types": {
      "types": "./dist/tools/intelligence-types/src/index.d.ts",
      "import": "./dist/tools/intelligence-types/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "lint": "echo \"No lint step configured\"",
    "test": "echo \"No tests configured\""
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.6",
    "fast-glob": "^3.3.3",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "typescript": "^5.6.3"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/i2c/nextjs-intelligence.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "intelligence",
    "analysis"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "registry": "https://artifacts-local.i2cinc.com/repository/dd-npm-private/"
  }
}
